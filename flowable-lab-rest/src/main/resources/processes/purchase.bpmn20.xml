<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://flowable.org/bpmn">

    <process id="purchase" name="采购审批流程" isExecutable="true">

        <startEvent id="startEvent" name="提交采购申请">
            <extensionElements>
                <flowable:formProperty id="applicant" name="申请人" type="string" required="true"/>
                <flowable:formProperty id="amount" name="采购金额" type="long" required="true"/>
                <flowable:formProperty id="purpose" name="采购用途" type="string" required="true"/>
            </extensionElements>
        </startEvent>

        <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="dmnTask"/>

        <serviceTask id="dmnTask" name="DMN决策评估"
                     flowable:delegateExpression="${dmnEvaluateDelegate}">
            <extensionElements>
                <flowable:field name="decisionKey">
                    <flowable:string><![CDATA[expense-approval]]></flowable:string>
                </flowable:field>
            </extensionElements>
        </serviceTask>

        <sequenceFlow id="flow2" sourceRef="dmnTask" targetRef="decisionGateway"/>

        <exclusiveGateway id="decisionGateway" name="决策网关"/>

        <sequenceFlow id="flow_auto" sourceRef="decisionGateway" targetRef="logTask">
            <conditionExpression xsi:type="tFormalExpression"><![CDATA[${decision == 'auto_approve'}]]></conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flow_need" sourceRef="decisionGateway" targetRef="parallelGateway">
            <conditionExpression xsi:type="tFormalExpression"><![CDATA[${decision == 'need_approval'}]]></conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flow_reject" sourceRef="decisionGateway" targetRef="rejectEnd">
            <conditionExpression xsi:type="tFormalExpression"><![CDATA[${decision == 'reject'}]]></conditionExpression>
        </sequenceFlow>

        <parallelGateway id="parallelGateway" name="并行审批"/>

        <userTask id="financeApproval" name="财务审批" flowable:assignee="finance_admin">
            <extensionElements>
                <flowable:formProperty id="approved" name="是否同意" type="boolean" required="true"/>
                <flowable:formProperty id="comment" name="审批意见" type="string"/>
            </extensionElements>
        </userTask>

        <userTask id="directorApproval" name="主管审批" flowable:assignee="manager">
            <extensionElements>
                <flowable:formProperty id="approved" name="是否同意" type="boolean" required="true"/>
                <flowable:formProperty id="comment" name="审批意见" type="string"/>
            </extensionElements>
        </userTask>

        <sequenceFlow id="flow_par1" sourceRef="parallelGateway" targetRef="financeApproval"/>
        <sequenceFlow id="flow_par2" sourceRef="parallelGateway" targetRef="directorApproval"/>

        <inclusiveGateway id="inclusiveGateway" name="包容汇合"/>

        <sequenceFlow id="flow_join1" sourceRef="financeApproval" targetRef="inclusiveGateway"/>
        <sequenceFlow id="flow_join2" sourceRef="directorApproval" targetRef="inclusiveGateway"/>

        <sequenceFlow id="flow_sub" sourceRef="inclusiveGateway" targetRef="callSubProcess"/>

        <callActivity id="callSubProcess" name="采购执行"
                      calledElement="purchase-execution"
                      flowable:inheritVariables="true"/>

        <sequenceFlow id="flow_sub_end" sourceRef="callSubProcess" targetRef="logTask"/>

        <serviceTask id="logTask" name="记录日志" flowable:delegateExpression="${logDelegate}"/>

        <sequenceFlow id="flow_log_end" sourceRef="logTask" targetRef="endEvent"/>

        <endEvent id="endEvent" name="结束"/>

        <endEvent id="rejectEnd" name="驳回结束"/>

    </process>

    <process id="purchase-execution" name="采购执行子流程" isExecutable="true">
        <startEvent id="subStart"/>
        <sequenceFlow id="sub_flow1" sourceRef="subStart" targetRef="orderTask"/>
        <userTask id="orderTask" name="下单采购" flowable:assignee="purchaser"/>
        <sequenceFlow id="sub_flow2" sourceRef="orderTask" targetRef="receiveTask"/>
        <userTask id="receiveTask" name="确认收货" flowable:assignee="purchaser"/>
        <sequenceFlow id="sub_flow3" sourceRef="receiveTask" targetRef="subEnd"/>
        <endEvent id="subEnd"/>
    </process>

</definitions>
