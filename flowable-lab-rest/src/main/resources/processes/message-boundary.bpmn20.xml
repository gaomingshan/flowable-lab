<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://flowable.org/bpmn">

    <process id="message-boundary" name="消息边界事件演示" isExecutable="true">

        <startEvent id="startEvent"/>

        <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="waitTask"/>

        <userTask id="waitTask" name="等待外部消息" flowable:assignee="admin"/>

        <boundaryEvent id="msgBoundary" attachedToRef="waitTask" cancelActivity="true">
            <messageEventDefinition messageRef="externalNotifyMsg"/>
        </boundaryEvent>

        <sequenceFlow id="flow2" sourceRef="waitTask" targetRef="normalEnd"/>

        <sequenceFlow id="flow_msg" sourceRef="msgBoundary" targetRef="msgHandler"/>

        <serviceTask id="msgHandler" name="处理消息通知"
                     flowable:delegateExpression="${logDelegate}"/>

        <sequenceFlow id="flow3" sourceRef="msgHandler" targetRef="normalEnd"/>

        <endEvent id="normalEnd"/>

    </process>

    <message id="externalNotifyMsg" name="externalNotifyMsg"/>

</definitions>
