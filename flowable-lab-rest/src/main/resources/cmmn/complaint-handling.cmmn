<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/CMMN/20151109/MODEL"
             xmlns:flowable="http://flowable.org/cmmn"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://flowable.org/cmmn">

    <case id="complaint-handling" name="投诉处理案例" flowable:initiatorVariableName="initiator">

        <casePlanModel id="casePlanModel" name="投诉处理" flowable:formFieldValidation="true">

            <planItem id="piReceive" definitionRef="receiveComplaint" name="受理投诉"/>
            <planItem id="piInvestigate" definitionRef="investigate" name="调查核实"/>
            <planItem id="piProcess" definitionRef="processComplaint" name="处理投诉"/>
            <planItem id="piReview" definitionRef="reviewResult" name="复核结果"/>
            <planItem id="piArchive" definitionRef="archiveMilestone" name="结案归档"/>

            <humanTask id="receiveComplaint" name="受理投诉" flowable:assignee="${initiator}">
                <extensionElements>
                    <flowable:formProperty id="complaintType" name="投诉类型" type="string" required="true"/>
                    <flowable:formProperty id="description" name="投诉描述" type="string" required="true"/>
                    <flowable:formProperty id="urgency" name="紧急程度" type="enum" required="true">
                        <flowable:value id="low" name="低"/>
                        <flowable:value id="medium" name="中"/>
                        <flowable:value id="high" name="高"/>
                    </flowable:formProperty>
                </extensionElements>
            </humanTask>

            <humanTask id="investigate" name="调查核实" flowable:assignee="cs_agent">
                <extensionElements>
                    <flowable:formProperty id="investigationResult" name="调查结果" type="string"/>
                    <flowable:formProperty id="evidence" name="证据说明" type="string"/>
                </extensionElements>
            </humanTask>

            <humanTask id="processComplaint" name="处理投诉" flowable:assignee="cs_manager">
                <extensionElements>
                    <flowable:formProperty id="solution" name="解决方案" type="string" required="true"/>
                    <flowable:formProperty id="compensation" name="补偿方案" type="string"/>
                </extensionElements>
            </humanTask>

            <humanTask id="reviewResult" name="复核结果" flowable:assignee="admin"/>

            <milestone id="archiveMilestone" name="结案归档"/>

            <criterion id="criInvestigate" name="">
                <condition><![CDATA[${true}]]></condition>
            </criterion>

            <entryCriterion id="entryInvestigate" sentryRef="criInvestigate" sourceRef="piReceive"/>

            <entryCriterion id="entryProcess" sentryRef="criInvestigate" sourceRef="piInvestigate"/>

            <entryCriterion id="entryReview" sentryRef="criInvestigate" sourceRef="piProcess"/>

            <entryCriterion id="entryArchive" sentryRef="criInvestigate" sourceRef="piReview"/>

        </casePlanModel>

    </case>

</definitions>
